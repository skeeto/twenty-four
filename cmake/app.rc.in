// Windows resources: EXE icon + version/file properties.
// Generated by CMake from cmake/app.rc.in using project metadata.
#include <windows.h>

IDI_ICON1 ICON "@TF_ICON_ICO@"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION    @TF_VER_MAJOR@,@TF_VER_MINOR@,@TF_VER_PATCH@,0
 PRODUCTVERSION @TF_VER_MAJOR@,@TF_VER_MINOR@,@TF_VER_PATCH@,0
 FILEFLAGSMASK  0x3fL
 FILEFLAGS      0x0L
 FILEOS         VOS_NT_WINDOWS32
 FILETYPE       VFT_APP
 FILESUBTYPE    0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "nullprogram"
            VALUE "FileDescription",  "Twenty Four"
            VALUE "FileVersion",      "@TF_VERSION@"
            VALUE "InternalName",     "twenty_four"
            VALUE "LegalCopyright",   "Public domain (Unlicense)"
            VALUE "OriginalFilename", "twenty_four.exe"
            VALUE "ProductName",      "Twenty Four"
            VALUE "ProductVersion",   "@TF_VERSION@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
